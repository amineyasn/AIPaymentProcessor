# ─────────────────────────────────────────────
# Acumatica Payment API — Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS — comma-separated allowed origins (use * for dev only)
CORS_ORIGINS=*
